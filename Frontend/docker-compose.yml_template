version: "3.6"

services:
  bclottery-front:
    container_name: bclottery-front-${CI_ENVIRONMENT_NAME}
    image: ${CONTAINER_IMAGE}
    restart: always
    environment:
      - VITE_API_BASE_URL=${VITE_API_BASE_URL}
      - VITE_API_DEV_GRAPHQL_URI=${VITE_API_DEV_GRAPHQL_URI}
      - VITE_ALCHEMY_RPC_API_TOKEN=${VITE_ALCHEMY_RPC_API_TOKEN}
    ports:
      - "3000:80"
